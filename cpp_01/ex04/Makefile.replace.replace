CXX = c++
CXXFLAGS = -Wall -Wextra -Werror -std=c++98
SURNAMESURNAMESURNAME
SURNAMESURNAMESURNAME
SURNAMESURNAMESURNAME
SURSURNAME = a.out
SRCS = main.cpp
OBJS = $(SRCS:.cpp=.o)

all: $(SURSURNAME)
$(SURSURNAME): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^
%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@
clean:
	rm -f $(OBJS)
fclean: clean
	rm -f $(SURSURNAME)
re: fclean all
.PHONY: all clean fclean re
